schemaVersion: 1
framework: pyflink
mode: plan-only

# 单机 Docker 集群模式：每台物理机运行 1JM + 2TM 容器
# client/jm/tm 角色在同一台机器上用 Docker network 通信
# 宿主机只需要 Docker，Java/Python/Flink 全部在容器内
#
# 使用方式：复制为 environment.yaml，将 hostRef / alias 替换为实际主机
#   cp environment.yaml.example environment.yaml
#
# alias 可以填 IP 地址（如 192.168.1.100）或 ~/.ssh/config 中的 Host 别名
# 同时可通过 user / key / port 指定连接参数，不填则使用 SSH config 默认值

platforms:
  - id: arm
    arch: aarch64
    hosts:
      - role: client
        hostRef: arm-host
      - role: jobmanager
        hostRef: arm-host
      - role: taskmanager
        hostRef: arm-host

  - id: x86
    arch: x86_64
    hosts:
      - role: client
        hostRef: x86-host
      - role: jobmanager
        hostRef: x86-host
      - role: taskmanager
        hostRef: x86-host

software:
  flinkImage: flink:2.2.0-java17
  flinkPyflinkImages:
    arm: flink-pyflink:2.2.0-py314-arm-final
    x86: flink-pyflink:2.2.0-py314-x86-final
  dockerRequired: true
  clusterTopology: 1jm-2tm
  containerNetwork: flink-network
  pythonVersion: "3.14.3"
  pyflinkVersion: "2.2.0"
  taskmanagerTmpfs: true  # TMs need --tmpfs /tmp:rw,exec to avoid /tmp permission issues
  profilingTools:
    - perf      # perf record / perf annotate / perf report
    - strace    # 系统调用追踪
    - objdump   # 二进制反汇编 (binutils)
    - gdb       # 调试符号查看
    - readelf   # ELF 信息查看

hostRefs:
  arm-host:
    connect: ssh
    alias: 192.168.1.100      # IP 地址或 SSH config 中的 Host 别名
    user: root                # 可选，不填则使用 SSH config 默认值
    key: ~/.ssh/id_rsa        # 可选，不填则使用 SSH config 默认值
    port: 22                  # 可选，默认 22
    capabilities:
      ssh: true
      sudo: true
      docker: true
      internet: true
      upload: true
      download: true

  x86-host:
    connect: ssh
    alias: 192.168.1.200      # IP 地址或 SSH config 中的 Host 别名
    capabilities:
      ssh: true
      sudo: true
      docker: true
      internet: true
      upload: true
      download: true
