{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.local/python-framework-analysis-pipeline/source.schema.json",
  "title": "Source",
  "type": "object",
  "required": ["id", "frameworkId", "repo", "sourceFiles", "sourceAnchors", "artifactIndex"],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "frameworkId": {
      "type": "string",
      "minLength": 1
    },
    "repo": {
      "type": "object"
    },
    "sourceFiles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "path"],
        "additionalProperties": true
      }
    },
    "sourceAnchors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "fileId"],
        "additionalProperties": true
      }
    },
    "artifactIndex": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "path"],
        "additionalProperties": true
      }
    }
  }
}
