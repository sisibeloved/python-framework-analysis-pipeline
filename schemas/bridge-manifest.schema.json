{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.local/python-framework-analysis-pipeline/bridge-manifest.schema.json",
  "title": "BridgeManifest",
  "description": "Tracks issue creation and resolution status for the Step 7 bridge.",
  "type": "object",
  "required": ["schema_version", "issues"],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "project_id": {
      "type": "string"
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["issue_type", "function_id", "platform", "repo", "issue_number", "status", "created_at"],
        "additionalProperties": true,
        "properties": {
          "issue_type": {
            "type": "string",
            "enum": ["asm-diff", "asm-diff-chunk"]
          },
          "function_id": {
            "type": "string"
          },
          "platform": {
            "type": "string",
            "enum": ["github", "gitcode"]
          },
          "repo": {
            "type": "string",
            "description": "owner/repo"
          },
          "issue_number": {
            "type": "integer"
          },
          "issue_url": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["created", "analysed", "parsed", "failed"]
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "parsed_at": {
            "type": "string",
            "format": "date-time"
          },
          "parent_issue_number": {
            "type": "integer",
            "description": "For chunk issues, points to the main issue."
          }
        }
      }
    }
  }
}
